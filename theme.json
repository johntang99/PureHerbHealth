  "_applyThemeSnippet": {
    "_comment": "Copy this script block into every HTML prototype, just before </head>. It reads THEME_JSON (embedded as a JS const) and sets all CSS custom properties on :root.",
    "code": [
      "// Paste the contents of theme.json as: const THEME_JSON = { ... };",
      "// Then call applyTheme(THEME_JSON); after DOM is ready.",
      "function applyTheme(t) {",
      "  const r = document.documentElement.style;",
      "  const c = t.colors;",
      "  // Brand",
      "  Object.entries(c.brand).forEach(([k,v]) => r.setProperty(`--brand-${k}`, v));",
      "  // Accent",
      "  Object.entries(c.accent).forEach(([k,v]) => r.setProperty(`--accent-${k}`, v));",
      "  // Neutral",
      "  Object.entries(c.neutral).forEach(([k,v]) => r.setProperty(`--neutral-${k}`, v));",
      "  // Elements",
      "  Object.entries(c.elements).forEach(([el,vals]) =>",
      "    Object.entries(vals).forEach(([k,v]) => r.setProperty(`--element-${el}-${k}`, v))",
      "  );",
      "  // Typography",
      "  r.setProperty('--font-heading', t.typography.fontHeading);",
      "  r.setProperty('--font-body',    t.typography.fontBody);",
      "  r.setProperty('--font-chinese', t.typography.fontChinese);",
      "  // Radius",
      "  Object.entries(t.radius).forEach(([k,v]) => r.setProperty(`--radius-${k}`, v));",
      "  // Shadows",
      "  Object.entries(t.shadows).forEach(([k,v]) => r.setProperty(`--shadow-${k}`, v));",
      "  // Transitions",
      "  Object.entries(t.transitions).forEach(([k,v]) => r.setProperty(`--transition-${k}`, v));",
      "}"
    ]
  }
